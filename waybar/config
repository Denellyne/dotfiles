{
  "layer": "top",
  "position": "top",

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": [
    "group/system"
  ],

  "group/system": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "pulseaudio",
      "custom/bluetooth",
      "custom/power"
    ]
  },
  "clock": {
    "format": "  {:%H:%M %d/%m/%y}"
  },

  "cpu": {
    "format": "  {usage}%"
  },

  "memory": {
    "format": "󰍛  {}%"
  },

  "network": {
    "format-wifi": "  {signalstrength}%",
    "format-ethernet": "󰈀 connected",
    "format-disconnected": "󰖪 offline"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "󰝟 muted",
    "format-icons": {
      "default": ["", "", ""]
    },

    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",

    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },
  "custom/bluetooth": {
    "exec": "~/.config/waybar/scripts/bluetoothStatus.sh",
    "interval": 3,
    "on-click": "~/.config/waybar/scripts/bluetoothMenu.sh"
  },
  "custom/power": {
    "format": "⏻ Power",
    "on-click" : "~/.config/waybar/scripts/powerMenu.sh"

  }

}
