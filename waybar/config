{
  "layer": "top",
  "position": "top",

  "modules-left": ["group/info"],
  "modules-center": ["custom/cava"],
  "modules-right": [
    "group/system"
  ],

  "group/info":{
    "orientation": "horizontal",
    "modules": ["clock","hyprland/workspaces"]
  },
  "group/system": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "pulseaudio",
      "custom/bluetooth",
      "battery",
      "custom/power",
      "group/drawer"
    ]
  },
"custom/cava": {
    "exec": "~/.config/waybar/scripts/cava.sh",
    "return-type": "json"
},
"group/drawer": {
  "orientation": "horizontal",
  "drawer": {
    "transition-duration": 300,
    "transition-left-to-right": true
  },
  "modules": [
    "custom/drawer-toggle",
    "network",
    "custom/temp",
    "backlight",
    "power-profiles-daemon"
  ]
},
"custom/drawer-toggle": {
  "format": " Misc ",
  "tooltip": true,
  "tooltip-format": "System drawer"
},
  "clock": {
    "format": "  {:%H:%M %d/%m/%y}",
  "tooltip": true,
  "tooltip-format" : "System Clock"
  },

  "cpu": {
    "format": "  {usage}%"
  },

  "memory": {
    "format": "󰍛  {}%"
  },

  "battery": {
    "bat": "BAT2",
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-icons": ["", "", "", "", ""]
  },

  "network": {
    "format-wifi": "  {signalstrength}%",
    "format-ethernet": "󰈀 connected",
    "format-disconnected": "󰖪 offline"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "󰝟 muted",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },

  "custom/bluetooth": {
    "exec": "~/.config/waybar/scripts/bluetoothStatus.sh",
    "interval": 3,
    "on-click": "~/.config/waybar/scripts/bluetoothMenu.sh"
  },

  "custom/power": {
    "format": "⏻ Power",
  "tooltip": true,
    "tooltip-format": "Power menu",
    "on-click": "~/.config/waybar/scripts/powerMenu.sh"
  },

  "backlight": {
    "format": " 󰃠 {percent}%"
  },

"custom/temp": {
    "format": "  Temperature",
  "exec": "bash -c 'cpu=$(awk \"{printf \\\"%d\\\", \\$1/1000}\" /sys/class/hwmon/hwmon4/temp1_input 2>/dev/null | head -n1); gpu=$(awk \"{printf \\\"%d\\\", \\$1/1000}\" /sys/class/drm/card2/device/hwmon/hwmon2/temp1_input 2>/dev/null | head -n1); echo \" ${cpu}°C  󰢮 ${gpu}°C\"'",
  "interval": 3,
  "tooltip": true,
  "tooltip-format": "{}"
},
  "power-profiles-daemon": {
    "format": " {icon}",
  "tooltip": true,
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    }
  }
}
