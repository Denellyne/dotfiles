{
  "layer": "top",
  "position": "top",

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": [
    "group/system"
  ],

  "group/system": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "pulseaudio",
      "custom/bluetooth",
      "battery",
      "custom/power",
      "group/drawer"
    ]
  },

"group/drawer": {
  "orientation": "horizontal",
  "drawer": {
    "transition-duration": 250,
    "transition-left-to-right": true
  },
  "modules": [
    "custom/drawer-toggle",
    "network",
    "custom/temp",
    "backlight",
    "power-profiles-daemon"
  ]
},
"custom/drawer-toggle": {
  "format": "ΎΑΥ Misc ",
  "tooltip": true,
  "tooltip-format": "System drawer"
},
  "clock": {
    "format": "ΎΑΩ  {:%H:%M %d/%m/%y}",
  "tooltip": true,
  "tooltip-format" : "System Clock"
  },

  "cpu": {
    "format": "ΎΜδ  {usage}%"
  },

  "memory": {
    "format": "≤░Ξδ  {}%"
  },

  "battery": {
    "bat": "BAT2",
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },

  "network": {
    "format-wifi": "ΎΘτ  {signalstrength}%",
    "format-ethernet": "≤░ΙΑ connected",
    "format-disconnected": "≤░Ψς offline"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "≤░ζθ muted",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },

  "custom/bluetooth": {
    "exec": "~/.config/waybar/scripts/bluetoothStatus.sh",
    "interval": 3,
    "on-click": "~/.config/waybar/scripts/bluetoothMenu.sh"
  },

  "custom/power": {
    "format": "έΠ╗ Power",
  "tooltip": true,
    "tooltip-format": "Power menu",
    "on-click": "~/.config/waybar/scripts/powerMenu.sh"
  },

  "backlight": {
    "format": " ≤░Δι {percent}%"
  },

"custom/temp": {
    "format": " ΎΜΚ Temperature",
  "exec": "bash -c 'cpu=$(awk \"{printf \\\"%d\\\", \\$1/1000}\" /sys/class/hwmon/hwmon4/temp1_input 2>/dev/null | head -n1); gpu=$(awk \"{printf \\\"%d\\\", \\$1/1000}\" /sys/class/drm/card2/device/hwmon/hwmon2/temp1_input 2>/dev/null | head -n1); echo \"ΎΜδ ${cpu}┬░C  ≤░λχ ${gpu}┬░C\"'",
  "interval": 3,
  "tooltip": true,
  "tooltip-format": "{}"
},
  "power-profiles-daemon": {
    "format": " {icon}",
  "tooltip": true,
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "format-icons": {
      "default": "ΎΔπ",
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver": "ΎΒυ"
    }
  }
}
