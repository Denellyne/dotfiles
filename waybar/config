{
  "layer": "top",
  "position": "top",
  "fixed-center" : true,

  "modules-left": ["group/info"],
  "modules-center": ["custom/cava"],
  "modules-right": [
    "group/system"
  ],

  "group/info":{
    "orientation": "horizontal",
    "modules": ["clock","custom/dynamic-pad","hyprland/workspaces"]
  },
  "group/system": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "pulseaudio",
      "custom/bluetooth",
      "battery",
      "custom/power",
      "group/drawer"
    ]
  },
"custom/dynamic-pad": {
"exec": "cat ~/.config/waybar/workspaces_pad.fifo",
    "restart-interval": 1,
    "tooltip": false
  },
  
"custom/cava": {
    "exec": "~/.config/waybar/scripts/cava.sh",
    "return-type": "json",
    "restart-interval": 1
},
"group/drawer": {
  "orientation": "horizontal",
  "drawer": {
    "transition-duration": 300,
    "transition-left-to-right": true
  },
  "modules": [
    "custom/drawer-toggle",
    "network",
    "custom/temp",
    "backlight",
    "power-profiles-daemon"
  ]
},
"custom/drawer-toggle": {
  "format": " Misc ",
  "tooltip": true,
  "tooltip-format": "System drawer"
},
  "clock": {
    "format": "  {:%H:%M %d/%m/%y}",
  "tooltip": true,
  "tooltip-format" : "System Clock"
  },

  "cpu": {
    "format": "  {usage}%"
  },

  "memory": {
    "format": "󰍛  {}%"
  },

  "battery": {
    "bat": "BAT2",
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-icons": ["", "", "", "", ""]
  },

  "network": {
    "format-wifi": "  {essid} {signalstrength}%",
    "format-ethernet": "󰈀 Connected",
    "format-disconnected": "󰖪 Offline"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "󰝟 Muted",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },

  "custom/bluetooth": {
    "exec": "~/.config/waybar/scripts/bluetoothStatus.sh",
    "on-click": "~/.config/waybar/scripts/bluetoothMenu.sh",
    "persistent" : true,
    "restart-interval": 1
  },

  "custom/power": {
    "format": "⏻ Power",
  "tooltip": true,
    "tooltip-format": "Power menu",
    "on-click": "~/.config/waybar/scripts/powerMenu.sh"
  },

  "backlight": {
    "format": " 󰃠 {percent}%"
  },

"custom/temp": {
    "format": "  Temperature",
  "exec": "~/.config/waybar/scripts/temp.sh",
  "persistent": true,
  "tooltip": true,
  "tooltip-format": "{}"
},
  "power-profiles-daemon": {
    "format": " {icon}",
  "tooltip": true,
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    }
  }
}
